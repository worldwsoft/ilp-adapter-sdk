{
	"compilerOptions": {
		"target": "ES2020",
		"module": "CommonJS",
		"moduleResolution": "Node",
		"declaration": true,
		"outDir": "dist",
		"rootDir": ".",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true
	},
	"include": [
		"blockchain.ts",
		"blockchain/**/*.ts"
	],
	"exclude": [
		"dist",
		"node_modules"
	]
}
