{
	"name": "@oari/router-interface-sdk",
	"version": "0.0.6",
	"scripts": {
		"prepare": "npm run build",
		"build": "tsc -p tsconfig.json"
	},
	"exports": {
		"./socket": {
			"types": "./dist/socket.d.ts",
			"default": "./dist/socket.js"
		},
		"./blockchain": {
			"types": "./dist/blockchain.d.ts",
			"default": "./dist/blockchain.js"
		},
		"./blockchain/protocol": {
			"types": "./dist/blockchain.protocol.d.ts",
			"default": "./dist/blockchain.protocol.js"
		}
	},
	"files": [
		"dist"
	],
	"devDependencies": {
		"@types/node": "25.3.5",
		"typescript": "5.8.2"
	},
	"dependencies": {
		"@mwni/log": "3.4.0"
	}
}
